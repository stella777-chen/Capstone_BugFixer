{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cantier.demo/schemas/ui-config-v1.json",
  "title": "UIConfigV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "children"],
  "properties": {
    "type": { "const": "MesPage" },
    "title": { "type": "string" },
    "children": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": { "$ref": "#/$defs/DashboardChild" }
    }
  },
  "$defs": {
    "DashboardChild": {
      "oneOf": [
        { "$ref": "#/$defs/CantierDashBoardCard" },
        { "$ref": "#/$defs/CantierSecondaryCard" }
      ]
    },

    "QueryV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "timeRange"],
      "properties": {
        "metric": {
          "type": "string",
          "enum": ["OEE", "Availability", "Performance", "Quality", "DowntimeMinutes", "OutputQty"]
        },
        "timeRange": {
          "type": "string",
          "enum": ["24h", "7d", "30d", "custom"]
        },
        "start": {
          "type": "string",
          "format": "date-time",
          "description": "Required when timeRange=custom (ISO 8601 date-time)"
        },
        "end": {
          "type": "string",
          "format": "date-time",
          "description": "Required when timeRange=custom (ISO 8601 date-time)"
        },
        "dimension": {
          "type": "string",
          "enum": ["line", "machine", "shift", "product", "reason"]
        },
        "filters": {
          "type": "array",
          "maxItems": 10,
          "items": { "$ref": "#/$defs/FilterV1" }
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "timeRange": { "const": "custom" } },
            "required": ["timeRange"]
          },
          "then": { "required": ["start", "end"] },
          "else": {
            "not": {
              "anyOf": [
                { "required": ["start"] },
                { "required": ["end"] }
              ]
            }
          }
        }
      ]
    },

    "FilterV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "op", "value"],
      "properties": {
        "field": {
          "type": "string",
          "enum": ["line", "machine", "shift", "product", "reason"]
        },
        "op": {
          "type": "string",
          "enum": ["=", "!=", "in", "contains", ">=", "<="]
        },
        "value": { "type": ["string", "number", "boolean", "array"] }
      }
    },

    "CantierDashBoardCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "dashboardItems"],
      "properties": {
        "type": { "const": "CantierDashBoardCard" },

        "hasIcon": {
          "type": "boolean",
          "default": true
        },

        "hasOption": {
          "type": "boolean",
          "default": true
        },

        "dashboardItems": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "amount", "colorCode"],
            "properties": {
              "label": {
                "type": "string",
                "description": "KPI name displayed on the card"
              },
              "amount": {
                "type": ["string", "number"],
                "description": "KPI value"
              },
              "colorCode": {
                "type": "string",
                "enum": ["red", "blue", "green", "orange"]
              },
              "iconName": {
                "type": "string",
                "description": "Frontend maps iconName to actual React icon"
              }
            }
          }
        }
      }
    },

    "CantierSecondaryCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "subtitle", "value", "colorCode"],
      "properties": {
        "type": { "const": "CantierSecondaryCard" },

        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string", "minLength": 0 },

        "value": { "type": ["string", "number"] },

        "colorCode": {
          "type": "string",
          "enum": ["red", "blue", "green", "orange"],
          "default": "red"
        },

        "className": { "type": "string" },

        "iconName": {
          "type": "string",
          "description": "Frontend maps iconName to an actual ReactNode icon"
        }
      }
    }
  }
}